#!/usr/bin/env sh

# Load scripting addition (required for space management)
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# Layout
yabai -m config layout bsp
yabai -m config window_placement second_child

# Padding and gaps
# yabai -m config external_bar all:32:0
yabai -m config top_padding    2
yabai -m config bottom_padding 2
yabai -m config left_padding   2
yabai -m config right_padding  2
yabai -m config window_gap     2

# Mouse
yabai -m config mouse_follows_focus off
yabai -m config mouse_modifier alt
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action swap

# Window settings
yabai -m config auto_balance off
yabai -m config split_ratio 0.50

# Unmanaged apps
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add title="^Settings$" manage=off
yabai -m rule --add title="^Preferences$" manage=off
yabai -m rule --add app="^System Information$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^Surfshark$" manage=off
yabai -m rule --add app="^Music$" manage=off
yabai -m rule --add app="^Calendar$" manage=off
yabai -m rule --add app="^Contacts$" manage=off
yabai -m rule --add app="^Messages$" manage=off
yabai -m rule --add app="^FaceTime$" manage=off
yabai -m rule --add app="^Maps$" manage=off
yabai -m rule --add app="^Weather$" manage=off
yabai -m rule --add app="^App Store$" manage=off
yabai -m rule --add app="^Photos$" manage=off
yabai -m rule --add app="^Preview$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Font Book$" manage=off
yabai -m rule --add app="^Passwords$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^Docker$" manage=off
yabai -m rule --add app="^Raycast$" manage=off
yabai -m rule --add app="^Steam$" manage=off
yabai -m rule --add app="^Telegram$" manage=off
yabai -m rule --add app="^iPhone Mirroring$" manage=off
yabai -m rule --add app="^FindMy$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Hex$" manage=off
# yabai -m rule --add app="^YouTube$" manage=off
# yabai -m rule --add title="^Zed — Settings$" manage=off
yabai -m rule --add title="^.*Settings.*$" manage=off

# Common macOS file dialogs
yabai -m rule --add title="^(Open|Save|Save As|Choose|Import|Export|Select files)$" manage=off
# macOS sheets/dialogs (best bet for file pickers)
yabai -m rule --add role="^AXSheet$" manage=off
yabai -m rule --add subrole="^AXSystemDialog$" manage=off
yabai -m rule --add role="^AXDialog$" manage=off

# Fix Ghostty tabs: macOS native tabs appear as separate windows to yabai
yabai -m signal --add app="^Ghostty$" event=window_created action="yabai -m space --layout bsp"
yabai -m signal --add app="^Ghostty$" event=window_destroyed action="yabai -m space --layout bsp"

yabai -m rule --add app="^Ghostty$" space=1
yabai -m rule --add app="^Google Chrome$" space=2

# Apply rules to windows that already exist at startup
yabai -m rule --apply

# keep at end
borders active_color=0xffe1e3e4 inactive_color=0xff494d64 width=2.0 &
